# Copy to ".env" for local development only.
# Render production: set these in the Render Dashboard (Environment).

# AI providers
GROQ_API_KEY=
COHERE_API_KEY=
OPENAI_API_KEY=

# Optional integrations
TELEGRAM_BOT_TOKEN=

# App config
LOG_LEVEL=INFO
SECRET_KEY=change-me
DATABASE_URL=

# Your assistant persona defaults (used by some modules)
USERNAME=User
ASSISTANT_NAME=Assistant

# Hosting safety toggles
DISABLE_AUTOMATION=1

